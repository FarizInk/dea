{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}