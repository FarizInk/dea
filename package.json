{
  "name": "my-bot",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm/transpile-only bot/main.ts",
    "start": "node build/main.js",
    "watch": "nodemon --exec npm run dev --watch bot --ext ts"
  },
  "dependencies": {
    "@discordx/importer": "^1.3.1",
    "@discordx/pagination": "^3.5.4",
    "@types/ms": "^0.7.34",
    "axios": "^1.7.7",
    "discord.js": "^14.15.3",
    "discordx": "^11.11.1",
    "dotenv": "^16.4.5",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.4",
    "nodemon": "^3.1.3",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  }
}