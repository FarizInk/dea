{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@": [
        "./src"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vite/client",
    ]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    ".routify/**.js"
  ]
}