{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-bot",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "./bot/*"],
    },
    "target": "ES2022",
    "types": [
      "vite/client",
    ]
  },
  "include": [
    "bot/**/*",
  ],
}